generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(uuid())
  name                  String
  email                 String                 @unique
  passwordHash          String                 @map("password_hash")
  profileImage          String?                @map("profile_image")
  phone                 String?
  country               String?
  currency              String                 @default("INR")
  emailNotifications    Boolean                @default(true) @map("email_notifications")
  appNotifications      Boolean                @default(true) @map("app_notifications")
  reminderNotifications Boolean                @default(true) @map("reminder_notifications")
  tokenVersion          Int                    @default(0) @map("token_version")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  budgets               Budget[]
  notifications         Notification[]
  recurringTransactions RecurringTransaction[]
  reminders             Reminder[]
  savingsGoals          SavingsGoal[]
  subscriptions         Subscription[]
  transactions          Transaction[]
  alertSettings         AlertSettings?

  @@map("users")
}

model Transaction {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")
  amount          Decimal      @db.Decimal(15, 2)
  category        String
  type            String
  description     String?
  source          String       @default("manual")
  externalId      String?      @unique @map("external_id")
  transactionDate DateTime     @default(now()) @map("transaction_date")
  createdAt       DateTime     @default(now()) @map("created_at")
  savingsGoalId   String?      @map("savings_goal_id")
  savingsGoal     SavingsGoal? @relation(fields: [savingsGoalId], references: [id])
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model RecurringTransaction {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  amount            Decimal  @db.Decimal(15, 2)
  category          String
  type              String
  description       String?
  frequency         String
  startDate         DateTime @map("start_date")
  nextExecutionDate DateTime @map("next_execution_date")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recurring_transactions")
}

model Reminder {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String
  description String?
  dueDate     DateTime @map("due_date")
  isCompleted Boolean  @default(false) @map("is_completed")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reminders")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  message   String
  type      String
  metadata  Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Subscription {
  id                     String   @id @default(uuid())
  userId                 String   @map("user_id")
  name                   String
  amount                 Decimal  @db.Decimal(15, 2)
  billingCycle           String
  startDate              DateTime @map("start_date")
  nextBillingDate        DateTime @map("next_billing_date")
  category               String   @default("Subscription")
  isActive               Boolean  @default(true) @map("is_active")
  recurringTransactionId String?  @unique @map("recurring_transaction_id")
  createdAt              DateTime @default(now()) @map("created_at")
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Budget {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  category     String
  monthlyLimit Decimal  @map("monthly_limit") @db.Decimal(15, 2)
  month        Int
  year         Int
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month, year])
  @@map("budgets")
}

model SavingsGoal {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  title         String
  targetAmount  Decimal       @map("target_amount") @db.Decimal(15, 2)
  currentAmount Decimal       @map("current_amount") @db.Decimal(15, 2)
  deadline      DateTime
  createdAt     DateTime      @default(now()) @map("created_at")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]

  @@map("savings_goals")
}

model AlertSettings {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  budgetThresholds Json     @default("[50, 80, 100, 110]") @map("budget_thresholds")
  goalThresholds   Json     @default("[25, 50, 80, 100]") @map("goal_thresholds")
  lowBalanceLimit  Decimal  @default(1000) @map("low_balance_limit") @db.Decimal(15, 2)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alert_settings")
}
